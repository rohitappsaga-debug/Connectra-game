# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connectra

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
RECONNECT_TOKEN_TTL_MINUTES=1

# ─────────────────────────────────────────────
# Client (Vite)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ─────────────────────────────────────────────
# Production (Docker)
# ─────────────────────────────────────────────
DOMAIN=localhost
POSTGRES_USER=connectra
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_DB=connectra

# ─────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────
# Railway
RAILWAY_TOKEN=your-railway-token
RAILWAY_SERVICE=your-service-id

# Vercel
VERCEL_TOKEN=your-vercel-token

# Supabase
SUPABASE_ACCESS_TOKEN=your-supabase-token
SUPABASE_PROJECT_ID=your-project-id

# Docker Hub
DOCKER_USERNAME=your-docker-username
DOCKER_TOKEN=your-docker-token
