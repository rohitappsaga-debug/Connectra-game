{
  "name": "connectra",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based multiplayer strategy board game",
  "scripts": {
    "dev": "pnpm --filter client --filter server --parallel run dev",
    "dev:client": "pnpm --filter client run dev",
    "dev:server": "pnpm --filter server run dev",
    "build": "pnpm db:generate && pnpm --filter @connectra/shared run build && pnpm --filter client --filter server run build",
    "build:client": "pnpm --filter client run build",
    "build:server": "pnpm --filter server run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter server run db:generate",
    "db:push": "pnpm --filter server run db:push",
    "db:migrate": "pnpm --filter server run db:migrate",
    "db:seed": "pnpm --filter server run db:seed",
    "db:studio": "pnpm --filter server run db:studio",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "type": "module"
}