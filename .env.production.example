# ─────────────────────────────────────────────
# Database (Production)
# ─────────────────────────────────────────────
# Set this to your production PostgreSQL connection string (e.g. Neon PostgreSQL with PgBouncer)
# Append sslmode=require for SSL encryption, and pgbouncer=true&connection_limit=10 for Neon's pooler.
DATABASE_URL=postgresql://user:password@ep-withered-union-at9mvecv-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=10

# ─────────────────────────────────────────────
# Server (Production)
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://connectra.yourdomain.com
# IMPORTANT: Generate a secure secret key for JWT in production
JWT_SECRET=your-production-jwt-secret-key-do-not-share
RECONNECT_TOKEN_TTL_MINUTES=5

# ─────────────────────────────────────────────
# Client (Production - Vite)
# ─────────────────────────────────────────────
VITE_API_URL=https://api.connectra.yourdomain.com
VITE_WS_URL=https://api.connectra.yourdomain.com

# ─────────────────────────────────────────────
# Production Docker Config
# ─────────────────────────────────────────────
DOMAIN=connectra.yourdomain.com
POSTGRES_USER=connectra
POSTGRES_PASSWORD=generate-a-secure-database-password
POSTGRES_DB=connectra
