# ─────────────────────────────────────────────
# Database (Production)
# ─────────────────────────────────────────────
# Neon PostgreSQL production connection URL. Use pooled hostname ending in -pooler
# parameters: sslmode=require (SSL encryption), pgbouncer=true (PgBouncer mode), connection_limit=10 (optimal pool size)
DATABASE_URL=postgresql://neondb_owner:password@ep-withered-union-at9mvecv-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=10

# ─────────────────────────────────────────────
# Server (Production)
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://connectra.yourdomain.com
JWT_SECRET=your-production-jwt-secret-key-do-not-share
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Room Settings
# ─────────────────────────────────────────────
ROOM_CODE_LENGTH=6
ROOM_EXPIRATION_MINUTES=30
ROOM_MAX_PLAYERS=2

# ─────────────────────────────────────────────
# Reconnection
# ─────────────────────────────────────────────
RECONNECT_TOKEN_TTL_MINUTES=5
