# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connectra

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=dev-only-secret-change-in-production
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Room Settings
# ─────────────────────────────────────────────
ROOM_CODE_LENGTH=6
ROOM_EXPIRATION_MINUTES=30
ROOM_MAX_PLAYERS=2

# ─────────────────────────────────────────────
# Reconnection
# ─────────────────────────────────────────────
RECONNECT_TOKEN_TTL_MINUTES=5
